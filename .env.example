# ==================== 数据库配置 ====================
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/edu_platform
POSTGRES_PASSWORD=postgres

# ==================== Redis 配置 ====================
REDIS_URL=redis://redis:6379/0

# ==================== MinIO 配置 ====================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ==================== Dify 配置 ====================
# Dify 自托管地址（Docker 内部网络使用 dify-nginx 服务名）
DIFY_API_URL=http://dify-nginx:80/v1
# Dify API Key（在 Dify 控制台 → 应用 → API 访问中获取）
DIFY_API_KEY=your-dify-api-key-here
# Dify 校对工作流 API Key
DIFY_PROOFREAD_API_KEY=your-proofread-workflow-api-key
# Dify 查重工作流 API Key
DIFY_DEDUP_API_KEY=your-dedup-workflow-api-key

# ==================== Dify 自托管配置 ====================
# Dify 密钥（生产环境请修改为随机字符串）
DIFY_SECRET_KEY=sk-edu-platform-dify-secret-key-change-me
# Dify 专用数据库
DIFY_DB_USERNAME=postgres
DIFY_DB_PASSWORD=difypassword
DIFY_DB_DATABASE=dify
# Dify 专用 Redis
DIFY_REDIS_PASSWORD=difyredis
# Weaviate 向量数据库 API Key
WEAVIATE_API_KEY=WVF5YThaHlkYwhGUSmCRgsX3tD5ngdN8pkih

# ==================== DeepSeek 配置 ====================
# DeepSeek API Key（在 Dify 控制台 → 设置 → 模型提供商中配置）
DEEPSEEK_API_KEY=your-deepseek-api-key-here
